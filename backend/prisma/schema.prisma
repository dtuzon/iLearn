// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  ADMINISTRATOR
  LEARNING_MANAGER
  DEPARTMENT_HEAD
  COURSE_CREATOR
  SUPERVISOR
  EMPLOYEE
}

enum ModuleType {
  PRE_QUIZ
  VIDEO
  WORKSHOP
  POST_QUIZ
  EVALUATION
  ONLINE_EVALUATION
  INTRODUCTION
  CLOSING
  LIVE_SESSION
  ASSIGNMENT
}





enum EnrollmentStatus {
  NOT_STARTED
  IN_PROGRESS
  PENDING_GRADING
  COMPLETED
}

enum CourseStatus {
  DRAFT
  PENDING_APPROVAL
  PUBLISHED
  ARCHIVED
  RETIRED
}



enum SubmissionStatus {
  PENDING
  PENDING_REVIEW
  APPROVED
  REJECTED
  NEEDS_REVISION
}

enum CheckerType {
  IMMEDIATE_SUPERIOR
  COURSE_CREATOR
  SPECIFIC_USER
}

enum TemplateCategory {

  COURSE_QUALITY
  KASH_EVALUATION
  BEHAVIORAL_180_DAY
}

enum KashDomain {
  KNOWLEDGE
  ATTITUDE
  SKILLS
  HABITS
}

enum EvalQuestionType {
  RATING_1_TO_5
  TEXT_RESPONSE
  YES_NO
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  ENUMERATION
  ESSAY
}




// ─────────────────────────────────────────────
// CORE MODELS
// ─────────────────────────────────────────────

model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  headUserId String? @unique
  head       User?   @relation("DeptHeadRelation", fields: [headUserId], references: [id], onDelete: SetNull)

  users User[] @relation("DeptMembers")

  @@map("departments")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String?  @unique
  passwordHash String
  firstName    String?
  lastName     String?
  middleInitial String?
  nickname     String?
  position     String?
  dateHire     DateTime?
  mobileNumber String?
  personalEmail String?
  hrisName     String?
  role         Role     @default(EMPLOYEE)
  isActive               Boolean  @default(true)
  requiresPasswordChange Boolean  @default(false)
  resetPasswordToken     String?  @unique
  resetPasswordExpires   DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt


  departmentId String?
  department   Department? @relation("DeptMembers", fields: [departmentId], references: [id])

  // Back-relation for Department Head
  headOfDepartment Department? @relation("DeptHeadRelation")

  enrollments       Enrollment[]
  transcripts       Transcript[]
  auditLogs         AuditLog[]
  coursesAsLecturer Course[]         @relation("LecturerCourses")
  coursesAsApprover Course[]         @relation("ApproverCourses")
  notifications     Notification[]


  activitySubmissions ActivitySubmission[]
  assignedSubmissions ActivitySubmission[] @relation("AssignedSubmissions")
  evaluationResponses EvaluationResponse[]
  batchCheckers       BatchChecker[]
  essaySubmissions    EssaySubmission[]


  
  // Direct Reporting Structure
  immediateSuperiorId String?
  immediateSuperior   User?   @relation("ReportingStructure", fields: [immediateSuperiorId], references: [id], onDelete: SetNull)
  subordinates        User[]  @relation("ReportingStructure")
  
  onlineEvaluations   OnlineEvaluationResult[] @relation("UserOnlineEvaluations")
  supervisorEvaluations BehavioralEvaluation[] @relation("SupervisorEvaluations")
  employeeEvaluations BehavioralEvaluation[] @relation("EmployeeEvaluations")
  learningPathEnrollments LearningPathEnrollment[]
  learningPathCertificates LearningPathCertificate[]
  announcements           Announcement[]


  @@map("users")
}

model SystemSettings {
  id                    String  @id @default(cuid())
  companyName           String  @default("Standard Insurance Co., Inc.")
  primaryColorHex       String  @default("#e8aa33")
  secondaryColorHex     String  @default("#10B981")
  // Portal Content & Branding
  companyLogoUrl        String?
  loginBackgroundUrl    String?
  passingScore          Int     @default(80)
  frontPageWelcomeText  String? @default("Welcome to the iLearn Portal")
  footerText            String? @default("© 2024 Standard Insurance Co., Inc. All Rights Reserved.")
  dashboardBulletinMessage String? @default("No active announcements.")
  
  visionTitle           String? @default("OUR VISION")
  visionText            String? @default("To be the most preferred and trusted insurance company in the country.")
  missionTitle          String? @default("OUR MISSION")
  missionText           String? @default("To provide excellent service and innovative products that meet the needs of our clients.")

  // Email Settings
  smtpServer           String? @default("smtp.example.com")
  smtpPort             Int?    @default(587)
  smtpUser             String?
  smtpPassword         String?
  senderEmail          String? @default("no-reply@example.com")

  // Storage Settings
  maxUploadSizeMb     Int?    @default(10)
  allowedFileTypes    String? @default(".pdf,.zip,.docx,.mp4")

  @@map("system_settings")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   // The user receiving the notification
  title     String
  message   String
  type      String   @default("INFO") // e.g., "INFO", "ACTION_REQUIRED", "SUCCESS"
  link      String?  // Optional URL to route to when clicked
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}



// ─────────────────────────────────────────────
// UNIFIED EVALUATION TEMPLATE ENGINE
// ─────────────────────────────────────────────

model EvaluationTemplate {
  id          String   @id @default(cuid())
  name        String   // e.g., "Standard Corporate Survey" or "Sales Dept K.A.S.H."
  description String?
  category    TemplateCategory
  isActive    Boolean  @default(true)
  questions   EvaluationQuestion[]
  modules     CourseModule[] // Modules that use this template
  courses     Course[]       // Courses that use this template as their survey
  createdAt   DateTime @default(now())


  @@map("evaluation_templates")
}

model EvaluationQuestion {
  id          String   @id @default(cuid())
  templateId  String
  text        String
  type        EvalQuestionType 
  kashDomain  KashDomain? // ONLY used if the template category is KASH_EVALUATION
  order       Int
  
  template    EvaluationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("evaluation_questions")
}

model EvaluationResponse {
  id          String   @id @default(cuid())
  courseId    String
  userId      String
  templateId  String
  evaluatorId String?  // Optional: If a manager is filling out the 180-day review for the learner
  answers     Json     // Store the Q&A pairs/ratings here
  submittedAt DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("evaluation_responses")
}





// ─────────────────────────────────────────────
// COURSES & MODULES
// ─────────────────────────────────────────────

model Course {
  id           String   @id @default(cuid())
  title        String
  description  String?
  thumbnailUrl String?
  status       CourseStatus @default(DRAFT)
  version      Int          @default(1)
  versionTag   String?      // Human-readable release label e.g. "2025 Compliance Refresh"
  changeSummary String?     @db.Text // Release notes written by creator at approval request time
  parentId     String?      // Links new versions to the original course
  isLatest     Boolean      @default(true) // Helper to quickly query the active version
  
  introContent   String? @db.Text
  closingContent String? @db.Text


  parent       Course?      @relation("CourseVersions", fields: [parentId], references: [id])
  versions     Course[]     @relation("CourseVersions")


  passingGrade Int      @default(80)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  targetAudience     String   @default("GENERAL") // GENERAL, PHASE_1_NEW_HIRE, PHASE_2_REGULARIZED
  targetDepartments  String[] @default([])
  hasCertificate     Boolean  @default(false)

  lecturerId String

  lecturer   User   @relation("LecturerCourses", fields: [lecturerId], references: [id])

  approvedById String?
  approvedBy   User?   @relation("ApproverCourses", fields: [approvedById], references: [id])

  evaluationFormId String?

  evaluationForm   EvaluationTemplate? @relation(fields: [evaluationFormId], references: [id])
  evaluationResponses EvaluationResponse[]


  modules             CourseModule[]
  enrollments         Enrollment[]
  transcripts         Transcript[]
  certificateTemplate CertificateTemplate?
  behavioralEvaluations BehavioralEvaluation[]
  learningPathCourses LearningPathCourse[]
  attachments         CourseAttachment[]
  batches             Batch[]
  batchCourseSchedules BatchCourseSchedule[]


  @@map("courses")
}

model CourseAttachment {
  id        String   @id @default(cuid())
  fileName  String
  fileUrl   String
  fileSize  Int?     // In bytes
  fileType  String?  // e.g., 'application/pdf'
  courseId  String
  moduleId  String?  // Linked to a specific module
  createdAt DateTime @default(now())

  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  module    CourseModule? @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@map("course_attachments")
}



model CourseModule {
  id               String     @id @default(cuid())
  title            String
  type             ModuleType
  sequenceOrder    Int
  contentUrlOrText String?    // Video file path, workshop instructions HTML, etc.
  durationSeconds  Int?       // For video modules
  facilitators     String[]   @default([])
  shuffleQuestions Boolean    @default(false)
  shuffleOptions   Boolean    @default(false)
  
  // Workshop/Activity Fields
  activityInstructions String?
  activityTemplateUrl  String?
  checkerType          CheckerType? @default(COURSE_CREATOR)
  specificCheckerId    String?

  // Live Session Fields
  meetingUrl     String?
  scheduledAt    DateTime?
  attendanceCode String?

  courseId String


  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  evaluationTemplateId String?
  evaluationTemplate   EvaluationTemplate? @relation(fields: [evaluationTemplateId], references: [id])


  attachments         CourseAttachment[]
  quizQuestions  QuizQuestion[]
  moduleProgress ModuleProgress[]
  onlineEvaluations OnlineEvaluationResult[]
  activitySubmissions ActivitySubmission[]
  batchLiveSessions   BatchLiveSession[]

  @@map("course_modules")
}


model ActivitySubmission {
  id            String   @id @default(cuid())
  moduleId      String
  userId        String
  batchId       String?
  batch         Batch?   @relation(fields: [batchId], references: [id])

  fileUrl       String?
  textResponse  String?
  status        SubmissionStatus @default(PENDING_REVIEW)
  score         Float?
  feedback      String? 
  submittedAt   DateTime @default(now())
  gradedAt      DateTime?
  gradedById    String?
  
  assignedCheckerId String?
  assignedChecker   User?    @relation("AssignedSubmissions", fields: [assignedCheckerId], references: [id])

  module        CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId], name: "user_module_submission")

  @@map("activity_submissions")
}



// ─────────────────────────────────────────────
// QUIZ ENGINE
// ─────────────────────────────────────────────

model QuizQuestion {
  id            String       @id @default(cuid())
  questionText  String
  sequenceOrder Int          @default(0)
  type          QuestionType @default(MULTIPLE_CHOICE)
  // For ESSAY: optional rubric/prompt and max score for checker grading
  essayPrompt   String?
  maxScore      Int?         // e.g. 5 → checker grades 1‑5

  // For ENUMERATION: grading strictness options
  enumCaseSensitive     Boolean @default(false) // false = case-insensitive
  enumOrderMatters      Boolean @default(false) // false = order-insensitive
  enumStrictPunctuation Boolean @default(false) // false = strips punctuation before compare

  moduleId String
  module   CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  options          QuizOption[]
  essaySubmissions EssaySubmission[]

  @@map("quiz_questions")
}

model QuizOption {
  id         String  @id @default(cuid())
  optionText String
  isCorrect  Boolean @default(false)

  questionId String
  question   QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("quiz_options")
}

model EssaySubmission {
  id         String           @id @default(cuid())
  questionId String
  userId     String
  moduleId   String
  response   String           @db.Text
  score      Float?
  feedback   String?          @db.Text
  status     SubmissionStatus @default(PENDING_REVIEW)
  gradedById String?
  submittedAt DateTime        @default(now())
  gradedAt    DateTime?

  batchId    String?
  batch      Batch?           @relation(fields: [batchId], references: [id], onDelete: SetNull)
  
  question   QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId]) // one answer per learner per question
  @@map("essay_submissions")
}

// ─────────────────────────────────────────────
// CERTIFICATE BUILDER
// ─────────────────────────────────────────────

model CertificateTemplate {
  id                 String  @id @default(cuid())
  backgroundImageUrl String?
  signatureImageUrl  String?
  designConfig       Json?

  courseId String? @unique
  course   Course? @relation(fields: [courseId], references: [id], onDelete: Cascade)

  learningPathId String? @unique
  learningPath   LearningPath? @relation(fields: [learningPathId], references: [id], onDelete: Cascade)

  @@map("certificate_templates")
}


// ─────────────────────────────────────────────
// ENROLLMENT & LEARNING LOOP PROGRESS
// ─────────────────────────────────────────────

model Enrollment {
  id                 String           @id @default(cuid())
  status             EnrollmentStatus @default(NOT_STARTED)
  currentModuleOrder Int              @default(0)
  enrolledAt         DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  completedAt        DateTime?
  dueDate            DateTime?
  reminder7DaySentAt DateTime?
  reminder3DaySentAt DateTime?
  reminder1DaySentAt DateTime?
  overdueAlertSentAt DateTime?





  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  courseId String
  course   Course @relation(fields: [courseId], references: [id])

  batchId            String?
  batch              Batch?           @relation(fields: [batchId], references: [id])

  moduleProgress     ModuleProgress[]

  evaluation180DayTriggered Boolean @default(false)

  @@unique([userId, courseId])

  @@map("enrollments")
}

model ModuleProgress {
  id          String    @id @default(cuid())
  completed   Boolean   @default(false)
  score       Int?      // Quiz score as a percentage (0–100)
  attempts    Int       @default(0)
  fileUrl     String?   // Workshop submission file path
  gradedBy    String?   // User ID of the Lecturer who graded
  gradeNote   String?   // Lecturer's feedback
  submittedAt DateTime?
  completedAt DateTime?

  enrollmentId String
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  moduleId String
  module   CourseModule @relation(fields: [moduleId], references: [id])

  @@unique([enrollmentId, moduleId])
  @@map("module_progress")
}

// ─────────────────────────────────────────────
// TRANSCRIPTS
// ─────────────────────────────────────────────

model Transcript {
  id                String   @id @default(cuid())
  completionDate    DateTime @default(now())
  certificatePdfUrl String?
  finalScore        Int?     // Averaged or post-quiz score recorded at completion

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  courseId String
  course   Course @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
  @@map("transcripts")
}

// ─────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  metadata  Json?    // e.g., { "targetUserId": "...", "changes": {...} }
  ipAddress String?
  timestamp DateTime @default(now())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

model OnlineEvaluationResult {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation("UserOnlineEvaluations", fields: [userId], references: [id], onDelete: Cascade)
  moduleId          String
  module            CourseModule @relation(fields: [moduleId], references: [id])
  comments          String?
  facilitatorRatings Json     // [{ "name": "...", "rating": 5 }]
  createdAt         DateTime @default(now())

  @@map("online_evaluation_results")
}

model BehavioralEvaluation {
  id              String   @id @default(cuid())
  evaluatorId     String
  evaluator       User     @relation("SupervisorEvaluations", fields: [evaluatorId], references: [id], onDelete: Cascade)
  employeeId      String
  employee        User     @relation("EmployeeEvaluations", fields: [employeeId], references: [id], onDelete: Cascade)
  courseId        String
  course          Course   @relation(fields: [courseId], references: [id])
  
  moduleRatings   Json     // [{ "moduleName": "...", "beforeRating": 5, "afterRating": 5, "explanation": "..." }]
  overallImpact   String
  createdAt       DateTime @default(now())

  @@map("behavioral_evaluations")
}

model LearningPath {
  id                String   @id @default(cuid())
  title             String
  description       String?
  thumbnailUrl      String?
  targetAudience    String?  // e.g., "Phase 1: Newly Hired"
  targetDepartments String[] // Array of department names
  status            CourseStatus @default(DRAFT)
  version           Int          @default(1)
  versionTag        String?      // Release label e.g. "2025 Core Curriculum"
  changeSummary     String?      @db.Text
  parentId          String?
  isLatest          Boolean      @default(true)
  
  hasCertificate    Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  parent            LearningPath? @relation("PathVersions", fields: [parentId], references: [id])
  versions          LearningPath[] @relation("PathVersions")

  pathCourses       LearningPathCourse[]
  enrollments       LearningPathEnrollment[]
  certificates      LearningPathCertificate[]
  certificateTemplate CertificateTemplate?
  batches           Batch[]
  
  @@map("learning_paths")
}


model LearningPathCertificate {
  id             String       @id @default(cuid())
  userId         String
  learningPathId String
  issuedAt       DateTime     @default(now())
  certificateUrl String?      // Optional: For stored PDFs

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  learningPath   LearningPath @relation(fields: [learningPathId], references: [id], onDelete: Cascade)

  @@unique([userId, learningPathId])
  @@map("learning_path_certificates")
}


model LearningPathCourse {
  id             String       @id @default(cuid())
  learningPathId String
  courseId       String
  order          Int          // 1, 2, 3, etc. for strict sequencing

  learningPath   LearningPath @relation(fields: [learningPathId], references: [id], onDelete: Cascade)
  course         Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([learningPathId, courseId]) // Prevent duplicate courses in the same path
  @@map("learning_path_courses")
}

model LearningPathEnrollment {
  id             String         @id @default(cuid())
  userId         String
  learningPathId String
  status         EnrollmentStatus @default(IN_PROGRESS)
  enrolledAt     DateTime       @default(now())
  completedAt    DateTime?
  dueDate        DateTime?
  reminder7DaySentAt DateTime?
  reminder3DaySentAt DateTime?
  reminder1DaySentAt DateTime?
  overdueAlertSentAt     DateTime?




  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  learningPath   LearningPath   @relation(fields: [learningPathId], references: [id], onDelete: Cascade)

  batchId        String?
  batch          Batch?         @relation(fields: [batchId], references: [id])

  @@unique([userId, learningPathId]) // Prevent double enrollment
  @@map("learning_path_enrollments")
}


model Announcement {
  id          String    @id @default(cuid())
  title       String
  content     String    @db.Text
  imageUrl    String?   // Optional URL for the motivational quote/event image
  expiresAt   DateTime? // Optional date for temporary posts (e.g., seasonal greetings)
  priority    String    @default("NORMAL")
  authorId    String
  createdAt   DateTime  @default(now())

  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("announcements")
}

model Batch {
  id               String    @id @default(cuid())
  name             String    // e.g., "Q3 K.A.S.H Onboarding"
  startDate        DateTime
  endDate          DateTime
  status           String    @default("UPCOMING") // UPCOMING, ACTIVE, COMPLETED, CANCELLED
  requires180DayEval Boolean  @default(false)

  // Target Content (Can wrap a single Course or a Learning Path)
  courseId         String?
  course           Course?   @relation(fields: [courseId], references: [id])
  learningPathId   String?
  learningPath     LearningPath? @relation(fields: [learningPathId], references: [id])

  // Relations
  enrollments             Enrollment[]
  learningPathEnrollments LearningPathEnrollment[]
  courseSchedules         BatchCourseSchedule[] 
  activityCheckers        BatchChecker[] 
  activitySubmissions     ActivitySubmission[]
  essaySubmissions        EssaySubmission[]
  liveSessions            BatchLiveSession[]

  // Pre-training notification tracking (prevents duplicate sends)
  notify30DaySentAt DateTime?
  notify7DaySentAt  DateTime?
  notify3DaySentAt  DateTime?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("batches")
}

// Allows overriding start/end dates for specific courses WITHIN a Learning Path batch
model BatchCourseSchedule {
  id        String    @id @default(cuid())
  batchId   String
  batch     Batch     @relation(fields: [batchId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course    @relation(fields: [courseId], references: [id])
  startDate DateTime?
  endDate   DateTime?
  order     Int       @default(0) // custom sequence within this specific batch

  @@unique([batchId, courseId])
  @@map("batch_course_schedules")
}

// Maps which staff members are responsible for checking/grading this batch
model BatchChecker {
  id        String   @id @default(cuid())
  batchId   String
  batch     Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  userId    String   // The supervisor/manager acting as the checker
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([batchId, userId])
  @@map("batch_checkers")
}

// Stores the auto-generated Zoom meeting credentials for each LIVE_SESSION
// module within a specific batch. Created automatically on batch finalization.
model BatchLiveSession {
  id             String   @id @default(cuid())
  batchId        String
  courseModuleId String   // The blueprint CourseModule that spawned this meeting
  zoomMeetingId  String   @unique
  zoomPasscode   String
  joinUrl        String?
  startUrl       String?  // Host start URL — for admin/facilitator use only
  scheduledAt    DateTime?
  topic          String

  batch        Batch        @relation(fields: [batchId], references: [id], onDelete: Cascade)
  courseModule CourseModule @relation(fields: [courseModuleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([batchId, courseModuleId]) // One Zoom meeting per LIVE_SESSION module per batch
  @@map("batch_live_sessions")
}
